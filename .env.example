NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
CRON_SECRET=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SITE_URL=https://investigatorevents.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare Turnstile (bot protection on newsletter signup)
# Create a free site at https://dash.cloudflare.com/?to=/:account/turnstile
# Site key is public (exposed in browser); secret key is server-only.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Apple Push Notifications (APNs)
# APNS_PRIVATE_KEY is the contents of your AuthKey_XXXXXXXXXX.p8. Paste the whole PEM block
# including the -----BEGIN PRIVATE KEY----- and -----END PRIVATE KEY----- lines.
# Vercel sometimes escapes newlines as literal \n — the sender handles both forms.
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.investigatorevents.app
APNS_PRIVATE_KEY=
